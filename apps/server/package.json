{
  "name": "@your_spotify/server",
  "version": "1.20.1",
  "private": true,
  "scripts": {
    "build": "rsbuild build",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "concurrently \"rsbuild build -w\" \"nodemon build/index.js\"",
    "migrate": "node ./build/index.js --migrate",
    "lint": "oxlint -c ../dev/.oxlintrc.json . && oxfmt -c ../dev/.oxfmtrc.json --check .",
    "lint:fix": "oxlint -c ../dev/.oxlintrc.json --fix . && oxfmt -c ../dev/.oxfmtrc.json ."
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "jsonwebtoken": "^9.0.3",
    "migrate": "^2.1.0",
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@your_spotify/dev": "workspace:*",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "ts-node": "^10.9.2",
    "typescript": "catalog:"
  }
}